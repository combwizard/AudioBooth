    "This will clear all cached cover images. They will be re-downloaded as needed." : {
      "comment" : "An alert message displayed when the user confirms clearing the image cache.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil rydde alle cachelagrede bogomslag. De vil blive downloadet igen efter behov."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht alle zwischengespeicherten Coverbilder. Sie werden bei Bedarf erneut geladen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todas las portadas almacenadas en caché. Se volverán a descargar cuando sea necesario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela effacera toutes les images de couverture en cache. Elles seront retéléchargées si nécessaire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo cancellerà tutte le immagini di copertina memorizzate nella cache. Verranno scaricate di nuovo quando necessario."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将清除所有缓存的封面图片。它们将依需要重新下载。"
          }
        },
        "zh-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將清除所有快取的封面圖片。它們將依需要重新下載。"
          }
        }
      }
    },
    "This will delete all downloaded content. This action cannot be undone." : {
      "comment" : "An alert message that appears when the user confirms clearing all downloads.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil slette alt downloadet indhold. Handlingen kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht alle heruntergeladenen Inhalte. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todo el contenido descargado. Esta acción es irreversible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera tout le contenu téléchargé. Cette action est irréversible."
          }
        },
        "it" : {
          "stringUnit" : {
