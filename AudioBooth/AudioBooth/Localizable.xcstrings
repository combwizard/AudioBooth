    "Rewind a small amount after a brief pause and more after long ones, scaling with how long you've been away." : {
      "comment" : "A description of the smart rewind feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spoler lidt tilbage efter en kort pause og mere efter længere pauser – afhængigt af hvor længe du har været væk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spult nach kurzen Pausen ein Stück und nach längeren Pausen mehr zurück – passend dazu, wie lange du weg warst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retrocede un poco tras una pausa breve y más tras pausas largas, según cuánto tiempo te hayas ausentado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recule un peu après une courte pause et davantage après une longue, selon la durée de votre absence."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riavvolge poco dopo brevi pause e di più dopo pause lunghe, in base a quanto sei stato via."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短暂停后倒退少许,长时间暂停后倒退更多,根据离开时长缩放。"
          }
